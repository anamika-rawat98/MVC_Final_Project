@model IEnumerable<OrderListItemViewModel>

@{
    ViewData["Title"] = "All Orders";
}

<h2 class="mb-3">Orders</h2>

@if (!Model.Any())
{
    <div class="alert alert-info">No orders have been created yet.</div>
}
else
{
    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Order #</th>
                <th>User</th>
                <th>Product</th>
                <th>Total</th>
                <th>Status</th>
                <th>Order Date</th>
                <th>Notes</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var order in Model)
        {
            <tr>
                <td>@order.Id</td>
                <td>
                    <strong>@order.CustomerName</strong><br />
                    <span class="text-muted">@order.CustomerEmail</span>
                </td>
                <td>@order.ProductName (@order.Quantity x @order.Price.ToString("C"))</td>
                <td>@order.Total.ToString("C")</td>
                <td>@order.Status</td>
                <td>@order.OrderDate.ToString("g")</td>
                <td>@(string.IsNullOrWhiteSpace(order.Notes) ? "-" : order.Notes)</td>
            </tr>
        }
        </tbody>
    </table>
}
