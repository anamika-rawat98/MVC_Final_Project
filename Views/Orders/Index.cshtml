@model IEnumerable<OrderListItemViewModel>

@{
    ViewData["Title"] = "My Orders";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>My Orders</h2>
    <a asp-action="Create" class="btn btn-primary">Create Order</a>
</div>

@if (TempData["OrderSuccess"] is string successMessage)
{
    <div class="alert alert-success">@successMessage</div>
}

@if (!Model.Any())
{
    <div class="alert alert-info">You have not created any orders yet.</div>
}
else
{
    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Order #</th>
                <th>Product</th>
                <th>Price</th>
                <th>Quantity</th>
                <th>Total</th>
                <th>Status</th>
                <th>Order Date</th>
                <th>Notes</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var order in Model)
        {
            <tr>
                <td>@order.Id</td>
                <td>@order.ProductName</td>
                <td>@order.Price.ToString("C")</td>
                <td>@order.Quantity</td>
                <td>@order.Total.ToString("C")</td>
                <td>@order.Status</td>
                <td>@order.OrderDate.ToString("g")</td>
                <td>@(string.IsNullOrWhiteSpace(order.Notes) ? "-" : order.Notes)</td>
            </tr>
        }
        </tbody>
    </table>
}
