@model IEnumerable<AdminRoleIndexViewModel>

@{
    ViewData["Title"] = "Manage Roles";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Manage Roles</h2>
    <div>
        <a asp-action="Create" class="btn btn-primary">Create Role</a>
        <a asp-action="Assign" class="btn btn-outline-primary">Assign Role</a>
    </div>
</div>

@if (TempData["RoleError"] is string roleError)
{
    <div class="alert alert-danger">@roleError</div>
}

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Role Name</th>
            <th>Users</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var role in Model)
    {
        <tr>
            <td>@role.Name</td>
            <td>@role.UserCount</td>
            <td>
                <a asp-action="Edit" asp-route-id="@role.Id" class="btn btn-sm btn-warning">Edit</a>
                <form asp-action="Delete" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@role.Id" />
                    <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>
